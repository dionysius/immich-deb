#!/bin/sh
set -e

# Prepare upgrade from < 2.7.5-4~: move config file for migration
if [ "$1" = "upgrade" ] && dpkg --compare-versions "$2" lt "2.7.5-4~"; then
  if [ -f /etc/default/immich-machine-learning ]; then
    mv -f /etc/default/immich-machine-learning /etc/immich/machine-learning.env.dpkg-migration
  fi
fi

#DEBHELPER#
