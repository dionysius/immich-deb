#!/bin/sh
set -e

if [ "$1" = "configure" ]; then
  if [ -f /etc/default/immich-server ]; then
    if ! dpkg-statoverride --list /etc/default/immich-server >/dev/null 2>&1; then
      chown root:immich /etc/default/immich-server
      chmod 0640 /etc/default/immich-server
    fi
  fi
fi

#DEBHELPER#
